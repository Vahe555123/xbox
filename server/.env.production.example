PORT=4000
NODE_ENV=production

# Postgres on the same server (adjust user/password/db)
DATABASE_URL=postgres://xbox:STRONG_DB_PASSWORD@localhost:5432/xbox_store

# Xbox APIs
XBOX_EMERALD_BASE_URL=https://emerald.xboxservices.com/xboxcomfd
XBOX_CATALOG_BASE_URL=https://displaycatalog.mp.microsoft.com
XBOX_CATALOG_MARKET=US
XBOX_CATALOG_LANGUAGE=en-US
XBOX_CATALOG_LOCALE=en-US
XBOX_PAGE_SIZE=25

CACHE_TTL=300

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

AXIOS_TIMEOUT=15000
AXIOS_RETRY_COUNT=2
AXIOS_RETRY_DELAY=500

# Same-origin: nginx serves the SPA and reverse-proxies /api, so both are the same URL
CLIENT_ORIGIN=https://YOUR_DOMAIN.com
API_PUBLIC_ORIGIN=https://YOUR_DOMAIN.com

# SMTP for deal notifications / email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-gmail@example.com
SMTP_APP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL=your-gmail@example.com
SMTP_FROM_NAME="Xbox Store"

AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_OAUTH_STATE_TTL_SECONDS=600
AUTH_TELEGRAM_LOGIN_TTL_SECONDS=300

# Same-origin redirects — the API lives under /api on the same domain
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN.com/api/auth/oauth/google/callback

VK_CLIENT_ID=your-vk-client-id
VK_CLIENT_SECRET=your-vk-client-secret
VK_REDIRECT_URI=https://YOUR_DOMAIN.com/api/auth/oauth/vk/callback
VK_API_VERSION=5.199

TELEGRAM_BOT_USERNAME=your_bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

JWT_SECRET=generate-with-openssl-rand-base64-32

ADMIN_EMAILS=you@example.com
ADMIN_TELEGRAM_IDS=
DEAL_CHECK_INTERVAL_HOURS=24
