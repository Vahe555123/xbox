PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/xbox_store

# Xbox Emerald API (powers the browse page at xbox.com/games/browse)
XBOX_EMERALD_BASE_URL=https://emerald.xboxservices.com/xboxcomfd
# Display Catalog (fallback for direct product lookups)
XBOX_CATALOG_BASE_URL=https://displaycatalog.mp.microsoft.com
XBOX_CATALOG_MARKET=US
XBOX_CATALOG_LANGUAGE=en-US
XBOX_CATALOG_LOCALE=en-US
XBOX_PAGE_SIZE=25

# Cache TTL in seconds
CACHE_TTL=300

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Axios timeouts (ms)
AXIOS_TIMEOUT=15000
AXIOS_RETRY_COUNT=2
AXIOS_RETRY_DELAY=500

# Frontend origin for CORS
CLIENT_ORIGIN=http://localhost:5173
API_PUBLIC_ORIGIN=http://localhost:4000

# Auth / email (example using Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FAMILY=4
SMTP_CONNECTION_TIMEOUT_MS=8000
SMTP_GREETING_TIMEOUT_MS=8000
SMTP_SOCKET_TIMEOUT_MS=10000
SMTP_USERNAME=your-gmail@example.com
SMTP_APP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL=your-gmail@example.com
SMTP_FROM_NAME="Xbox Store"

AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_OAUTH_STATE_TTL_SECONDS=600
AUTH_TELEGRAM_LOGIN_TTL_SECONDS=300

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/oauth/google/callback

VK_CLIENT_ID=your-vk-client-id
VK_CLIENT_SECRET=your-vk-client-secret
VK_REDIRECT_URI=http://localhost:4000/api/auth/oauth/vk/callback
VK_API_VERSION=5.199

TELEGRAM_BOT_USERNAME=your_bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_POLLING=true
TELEGRAM_BOT_POLL_INTERVAL_MS=3000
TELEGRAM_BOT_REQUEST_TIMEOUT_MS=8000
TELEGRAM_WEBHOOK_SECRET=

JWT_SECRET=change-this-in-production

# Digiseller
DIGISELLER_SELLER_ID=1279033
DIGISELLER_API_KEY=your-digiseller-api-key
DIGISELLER_TOPUP_CARD_PRODUCT_ID=4629284
DIGISELLER_CART_BASE_URL=https://shop.digiseller.ru
DIGISELLER_CART_CURRENCY=API_17432_RUB
DIGISELLER_CART_PAYMENT_CURRENCY=API_5020_RUB
DIGISELLER_PAY_API_BASE_URL=https://www.oplata.info/asp2/pay_api.asp
